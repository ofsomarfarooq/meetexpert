<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>MeetExpert - Home</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="logo">MeetExpert</div>
    <input type="text" placeholder="Search experts, skills, companies...">
    <ul>
      {{#if user}}
        <li><a href="/">Home</a></li>
        <li><a href="#">Messenger</a></li>
        <li><a href="#">Notifications</a></li>
        <li class="dropdown">
          <img src="{{#if user.profile_picture}}{{user.profile_picture}}{{else}}/default-avatar.png{{/if}}" alt="Avatar" class="avatar-btn">
          <div class="dropdown-content">
            <a  href="/profile">My Profile</a>
            <a  href="/settings">Settings</a>
            <a  href="/auth/logout">Logout</a>
          </div>
        </li>
      {{else}}
        <li><a href="/">Home</a></li>
        <li><a href="#">Messenger</a></li>
        <li><a href="#">Notifications</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/register">Register</a></li>
      {{/if}}
    </ul>
  </nav>

  <main>
    {{#if message}}
      <h4 class="alert alert-success mt-2">{{message}}</h4>
    {{/if}}
    <h1>Welcome to MeetExpert</h1>
    <p>Find experts and learn skills directly from professionals.</p>
  </main>

  <script src="/script.js"></script>
</body>
</html>